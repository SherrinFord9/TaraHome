{
  "version": 2,
  "timezone": "America/Los_Angeles",
  "publishing": {
    "newArticlesPerDay": 1,
    "primaryRun": "06:00",
    "retryRun": "18:00",
    "retryOnlyWhenDailyArticleIsMissing": true,
    "skipWhenNoStrongDistinctTopicExists": true
  },
  "dailyStrategy": {
    "lane": "home-assistant-demand",
    "appliesEveryDay": true,
    "focus": "A specific Home Assistant setup, troubleshooting, compatibility, migration, automation, or buying question supported by current search and community demand",
    "researchWindowDays": 45,
    "minimumIndependentCommunitySignals": 2,
    "requireGoogleResultsReview": true,
    "requireCurrentOfficialSources": true,
    "requireTopicBrief": true,
    "minimumSelectionScore": 8
  },
  "keywordPlacement": {
    "requiredPhrase": "Home Assistant",
    "requiredIn": [
      "primary query",
      "HTML title",
      "H1",
      "opening answer",
      "meta description"
    ],
    "naturalLanguageOnly": true,
    "metaKeywordsTag": false
  },
  "intentPriorities": [
    "exact troubleshooting symptom or error",
    "setup or migration task",
    "device compatibility or local-control decision",
    "current product comparison or buying decision",
    "automation, dashboard, presence, camera, energy, or voice problem"
  ],
  "selectionScoring": {
    "communityDemand": "0-3",
    "queryClarity": "0-2",
    "answerability": "0-2",
    "siteFit": "0-2",
    "freshness": "0-2",
    "resultGap": "0-2",
    "cannibalizationRisk": "subtract 0-3",
    "minimumTotal": 8
  },
  "guardrails": {
    "newPageRequired": true,
    "distinctPrimaryQueryRequired": true,
    "homeAssistantFirstTopicRequired": true,
    "twoIndependentCommunitySignalsRequired": true,
    "singleViralThreadIsInsufficient": true,
    "searchResultGapMustBeExplained": true,
    "ikeaSpecificMaximumInRollingSevenDays": 1,
    "avoidNearDuplicateMatterAndThreadPermutations": true,
    "homepageAndProtectedCommercialMetadataMustNotChange": true
  },
  "commercialPath": "Link naturally to the most relevant Tara kit page and include one restrained configurator CTA."
}
