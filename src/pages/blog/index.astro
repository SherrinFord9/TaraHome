---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout
  title="Smart Home Guides — TARA Blog"
  description="How-to guides for building a truly intelligent, private smart home. Learn about hubs, lighting, Matter protocol, presence detection, and security."
>
  <Nav />

  <main class="relative z-10 pt-28 pb-24">
    <div class="mx-auto max-w-7xl px-6">

      <!-- Header -->
      <div class="text-center mb-16">
        <p class="section-label">Blog</p>
        <h1 class="font-[var(--font-display)] text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4">
          Smart Home Guides
        </h1>
        <p class="text-lg text-gray-400 max-w-2xl mx-auto">
          How-to guides, deep dives, and practical advice for building a truly
          intelligent, private smart home.
        </p>
      </div>

      <!-- Article Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => {
          const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });
          return (
            <a
              href={`/blog/${post.id}/`}
              class="glass-card p-6 group block"
            >
              <!-- Category + Read Time -->
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-medium uppercase tracking-widest text-amber-400/60">
                  {post.data.category}
                </span>
                <span class="text-gray-700">•</span>
                <span class="text-xs text-gray-600">{post.data.readTime}</span>
              </div>

              <!-- Title -->
              <h2 class="font-[var(--font-display)] text-lg font-semibold text-white mb-3 group-hover:text-amber-400/80 transition-colors leading-snug">
                {post.data.title}
              </h2>

              <!-- Description -->
              <p class="text-sm text-gray-500 leading-relaxed mb-4 line-clamp-3">
                {post.data.description}
              </p>

              <!-- Date -->
              <span class="text-xs text-gray-600">{formattedDate}</span>
            </a>
          );
        })}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
