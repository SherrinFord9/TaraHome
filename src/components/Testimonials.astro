---
// Testimonials — 3 cards with social proof
const testimonials = [
  {
    quote: "I was done with Alexa listening to everything. TARA gave me voice control back — without the surveillance. My home actually responds faster now that everything runs locally.",
    name: "Sarah K.",
    role: "Homeowner",
    image: "/assets/images/people/women.jpg",
  },
  {
    quote: "I've been running Home Assistant for 3 years. TARA is what I was trying to build myself — but it actually works without me touching YAML at midnight.",
    name: "James R.",
    role: "Software Engineer",
    image: "/assets/images/people/man2.jpg",
  },
  {
    quote: "We installed TARA in our model unit. Buyers spend twice as long in the smart home demo than any other room. It's become our #1 selling feature.",
    name: "Priya M.",
    role: "Development Director",
    image: "/assets/images/people/man.jpg",
  },
];
---

<section class="relative z-10 py-24 md:py-32">
  <div class="mx-auto max-w-7xl px-6">

    <!-- Section Label -->
    <p class="section-label text-center slide-fade">Early Adopters</p>

    <!-- Headline -->
    <h2 class="font-[var(--font-display)] text-3xl md:text-4xl font-extrabold text-center tracking-tight mb-16 heading-glow slide-scale" data-duration="1.1">
      <span class="heading-gradient">Built for People Who Care About Privacy.</span>
    </h2>

    <!-- Testimonial Cards — slide up with subtle rotation -->
    <div class="grid md:grid-cols-3 gap-6 mb-16">
      {testimonials.map((t) => (
        <div class="glass-card p-8 slide-rotate">
          <!-- Quote mark -->
          <span class="text-4xl text-purple-400/20 font-serif leading-none block mb-4">"</span>

          <!-- Quote -->
          <p class="text-base text-gray-300 leading-relaxed mb-6">
            {t.quote}
          </p>

          <!-- Attribution -->
          <div class="flex items-center gap-3">
            <img
              src={t.image}
              alt={t.name}
              class="w-10 h-10 rounded-full object-cover opacity-80"
              loading="lazy"
            />
            <div>
              <p class="text-sm text-gray-300 font-medium">{t.name}</p>
              <p class="text-sm text-gray-500">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Trust Badges -->
    <div class="flex flex-wrap items-center justify-center gap-8 text-gray-600 slide-fade" data-delay="300">
      <span class="text-sm opacity-40 hover:opacity-100 transition-opacity">Home Assistant</span>
      <span class="text-sm opacity-40 hover:opacity-100 transition-opacity">Matter</span>
      <span class="text-sm opacity-40 hover:opacity-100 transition-opacity">Thread</span>
      <span class="text-sm opacity-40 hover:opacity-100 transition-opacity">Zigbee Alliance</span>
      <span class="text-sm opacity-40 hover:opacity-100 transition-opacity">Open Source Hardware</span>
    </div>
  </div>
</section>
