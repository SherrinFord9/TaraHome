---
// Solution section — "Meet TARA" + 3 differentiators
---

<section class="relative z-10 py-24 md:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Text Column — slides in from left -->
      <div class="slide-left" data-duration="1.0">
        <!-- Section Label -->
        <p class="section-label">The Solution</p>

        <!-- Headline -->
        <h2 class="font-[var(--font-display)] text-3xl md:text-4xl font-extrabold tracking-tight mb-6 heading-glow">
          <span class="heading-gradient">Meet TARA. Intelligence That Lives With You.</span>
        </h2>

        <!-- Body -->
        <div class="space-y-4 text-lg text-gray-400 leading-relaxed mb-10">
          <p>
            TARA is a complete home intelligence system that processes everything locally.
            Your voice commands, your automation rules, your camera feeds — nothing leaves
            your home. Ever.
          </p>
          <p>
            She learns when you wake up, how you like your lights, and when to lock the
            door. Not because she's watching — because she's listening to the rhythm of
            your home.
          </p>
        </div>

        <!-- 3 Differentiators -->
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-amber-400/[0.08] flex items-center justify-center">
              <svg class="w-5 h-5 text-amber-400/70" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-base font-semibold text-white mb-1">Thinks locally</h3>
              <p class="text-sm text-gray-400">On-device AI processes everything in your home</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-amber-500/[0.08] flex items-center justify-center">
              <svg class="w-5 h-5 text-amber-500/70" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728L5.636 5.636m12.728 12.728A9 9 0 015.636 5.636"/>
              </svg>
            </div>
            <div>
              <h3 class="text-base font-semibold text-white mb-1">No cameras needed</h3>
              <p class="text-sm text-gray-400">mmWave radar senses presence through walls</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-amber-400/[0.08] flex items-center justify-center">
              <svg class="w-5 h-5 text-amber-400/70" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-base font-semibold text-white mb-1">Your data stays home</h3>
              <p class="text-sm text-gray-400">Zero bytes ever leave your network</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Visual Column — Living room photo in glass frame -->
      <div class="flex items-center justify-center slide-right" data-delay="200" data-duration="1.1">
        <div class="relative w-full max-w-md">
          <!-- Ambient glow behind image -->
          <div class="absolute -inset-4 rounded-3xl bg-gradient-to-br from-amber-500/10 via-transparent to-amber-700/5 blur-2xl"></div>

          <!-- Glass-framed image -->
          <div class="relative rounded-2xl overflow-hidden border border-white/[0.08] shadow-2xl">
            <img
              src="/assets/images/sections/solution-home.jpg"
              alt="Modern smart living room powered by TARA"
              class="w-full h-auto object-cover"
              loading="lazy"
            />
            <!-- Gradient overlay — blends bottom edge into dark bg -->
            <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-transparent to-transparent opacity-60"></div>
            <!-- Subtle amber tint -->
            <div class="absolute inset-0 bg-gradient-to-br from-amber-900/10 via-transparent to-transparent"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
