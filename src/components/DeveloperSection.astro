---
// Developer / Builder section — B2B value props + comparison table
---

<section id="developers" class="relative z-10 py-24 md:py-32 overflow-hidden">
  <!-- Atmospheric background image -->
  <div class="absolute inset-0 z-0">
    <img
      src="/assets/images/sections/dev-building.jpg"
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover object-bottom opacity-[0.10]"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#0A0A0B] via-[#050510]/80 to-[#0A0A0B]"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6">

    <!-- Section Label -->
    <p class="section-label text-center slide-fade">For Developers & Builders</p>

    <!-- Headline -->
    <h2 class="font-[var(--font-display)] text-3xl md:text-4xl font-extrabold text-center tracking-tight mb-4 heading-glow slide-scale" data-duration="1.1">
      <span class="heading-gradient">The Smartest Upgrade You Can Offer.</span>
    </h2>

    <!-- Subheadline -->
    <p class="text-lg text-gray-400 text-center max-w-2xl mx-auto mb-16 slide-fade" data-delay="200">
      Differentiate your development with built-in intelligence. No ongoing
      support burden. No vendor lock-in. Your buyers get a home that thinks —
      and you get a listing that sells.
    </p>

    <!-- 3 Value Prop Cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-16">

      <!-- Premium Positioning -->
      <div class="glass-card p-8 slide-rotate">
        <span class="font-[var(--font-display)] text-3xl font-bold gold-shine block mb-4">3-5%</span>
        <h3 class="font-[var(--font-display)] text-xl font-semibold text-white mb-3">
          Premium Positioning
        </h3>
        <p class="text-base text-gray-400 leading-relaxed">
          Homes with TARA sell for 3-5% more. In a 48-unit development,
          that's the difference between good and exceptional. "Smart home
          included" becomes your headline.
        </p>
      </div>

      <!-- Zero Support -->
      <div class="glass-card p-8 slide-rotate">
        <span class="font-[var(--font-display)] text-3xl font-bold gold-shine block mb-4">$0/mo</span>
        <h3 class="font-[var(--font-display)] text-xl font-semibold text-white mb-3">
          Zero Support Overhead
        </h3>
        <p class="text-base text-gray-400 leading-relaxed">
          Residents own their systems. No helpdesk, no monthly contracts,
          no integrator on retainer. TARA runs autonomously. If it works
          on day one, it works on day one thousand.
        </p>
      </div>

      <!-- Outclass Competition -->
      <div class="glass-card p-8 slide-rotate">
        <span class="font-[var(--font-display)] text-3xl font-bold gold-shine block mb-4">60-70%</span>
        <h3 class="font-[var(--font-display)] text-xl font-semibold text-white mb-3">
          Outclass the Competition
        </h3>
        <p class="text-base text-gray-400 leading-relaxed">
          Control4 charges $50K+ per unit with $150/month maintenance.
          Savant locks buyers into proprietary hardware. TARA delivers
          more intelligence at a fraction of the cost — on open hardware.
        </p>
      </div>
    </div>

    <!-- Comparison Table -->
    <div class="glass-card overflow-hidden mb-12 slide-fade" data-delay="200">
      <button
        id="comparison-toggle"
        class="w-full flex items-center justify-between px-8 py-5 text-left hover:bg-white/[0.02] transition-colors"
      >
        <span class="font-[var(--font-display)] text-lg font-semibold text-white">
          How TARA Compares
        </span>
        <svg id="comparison-chevron" class="w-5 h-5 text-gray-500 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
      <div id="comparison-table" class="hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-t border-white/[0.06]">
                <th class="text-left px-6 py-3 text-gray-500 font-medium">Feature</th>
                <th class="px-6 py-3 text-purple-400 font-semibold bg-purple-500/[0.04]">TARA</th>
                <th class="px-6 py-3 text-gray-500 font-medium">Control4</th>
                <th class="px-6 py-3 text-gray-500 font-medium">Savant</th>
                <th class="px-6 py-3 text-gray-500 font-medium hidden sm:table-cell">Alexa/Google</th>
              </tr>
            </thead>
            <tbody class="text-gray-400">
              <tr class="border-t border-white/[0.04]">
                <td class="px-6 py-3 text-gray-300">Local processing</td>
                <td class="px-6 py-3 text-center bg-purple-500/[0.04] text-green-400">Yes</td>
                <td class="px-6 py-3 text-center text-red-400/70">No</td>
                <td class="px-6 py-3 text-center text-red-400/70">No</td>
                <td class="px-6 py-3 text-center text-red-400/70 hidden sm:table-cell">No</td>
              </tr>
              <tr class="border-t border-white/[0.04]">
                <td class="px-6 py-3 text-gray-300">Monthly fee</td>
                <td class="px-6 py-3 text-center bg-purple-500/[0.04] text-green-400">$0</td>
                <td class="px-6 py-3 text-center">$50-150</td>
                <td class="px-6 py-3 text-center">$100-300</td>
                <td class="px-6 py-3 text-center hidden sm:table-cell">Free*</td>
              </tr>
              <tr class="border-t border-white/[0.04]">
                <td class="px-6 py-3 text-gray-300">Local AI assistant</td>
                <td class="px-6 py-3 text-center bg-purple-500/[0.04] text-green-400">Yes</td>
                <td class="px-6 py-3 text-center text-red-400/70">No</td>
                <td class="px-6 py-3 text-center text-red-400/70">No</td>
                <td class="px-6 py-3 text-center text-red-400/70 hidden sm:table-cell">No</td>
              </tr>
              <tr class="border-t border-white/[0.04]">
                <td class="px-6 py-3 text-gray-300">Camera privacy</td>
                <td class="px-6 py-3 text-center bg-purple-500/[0.04] text-green-400">100% local</td>
                <td class="px-6 py-3 text-center">Cloud</td>
                <td class="px-6 py-3 text-center">Cloud</td>
                <td class="px-6 py-3 text-center hidden sm:table-cell">Cloud</td>
              </tr>
              <tr class="border-t border-white/[0.04]">
                <td class="px-6 py-3 text-gray-300">Open hardware</td>
                <td class="px-6 py-3 text-center bg-purple-500/[0.04] text-green-400">Yes</td>
                <td class="px-6 py-3 text-center text-red-400/70">No</td>
                <td class="px-6 py-3 text-center text-red-400/70">No</td>
                <td class="px-6 py-3 text-center text-red-400/70 hidden sm:table-cell">No</td>
              </tr>
              <tr class="border-t border-white/[0.04]">
                <td class="px-6 py-3 text-gray-300">Offline capable</td>
                <td class="px-6 py-3 text-center bg-purple-500/[0.04] text-green-400">Full</td>
                <td class="px-6 py-3 text-center text-red-400/70">No</td>
                <td class="px-6 py-3 text-center text-red-400/70">No</td>
                <td class="px-6 py-3 text-center text-red-400/70 hidden sm:table-cell">No</td>
              </tr>
              <tr class="border-t border-white/[0.04]">
                <td class="px-6 py-3 text-gray-300">Setup time</td>
                <td class="px-6 py-3 text-center bg-purple-500/[0.04] text-green-400">Days</td>
                <td class="px-6 py-3 text-center">Weeks</td>
                <td class="px-6 py-3 text-center">Weeks</td>
                <td class="px-6 py-3 text-center hidden sm:table-cell">Hours</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center reveal" data-delay="100">
      <a
        href="mailto:hello@tarahome.ai?subject=Developer Partnership Inquiry"
        class="btn-primary text-lg px-10 py-4"
      >
        Partner With Us →
      </a>
      <p class="text-sm text-gray-500 mt-4">
        We'll walk you through a demo unit and custom pricing for your development.
      </p>
    </div>
  </div>
</section>

<script>
  const toggle = document.getElementById('comparison-toggle');
  const table = document.getElementById('comparison-table');
  const chevron = document.getElementById('comparison-chevron');
  toggle?.addEventListener('click', () => {
    table?.classList.toggle('hidden');
    chevron?.classList.toggle('rotate-180');
  });
</script>
