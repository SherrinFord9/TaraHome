---
// Final CTA section — headline + waitlist form
import WaitlistForm from './WaitlistForm.astro';
---

<section id="waitlist" class="relative z-10 py-24 md:py-32 overflow-hidden">
  <!-- Atmospheric background — luxury home -->
  <div class="absolute inset-0 z-0">
    <img
      src="/assets/images/sections/cta-house-night.jpg"
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover opacity-[0.10]"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-[#050505]/60 to-[#050505]/90"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-3xl px-6 text-center">

    <!-- Headline -->
    <h2 class="font-[var(--font-display)] text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight mb-6 heading-glow slide-scale" data-duration="1.2">
      <span class="heading-gradient">Your Home. Your Intelligence. Your Rules.</span>
    </h2>

    <!-- Subtext -->
    <p class="text-lg text-gray-400 mb-10 slide-fade" data-delay="200">
      Join the waitlist and be among the first to experience
      a home that thinks privately.
    </p>

    <!-- Waitlist Form — slides up -->
    <div class="reveal" data-delay="400">
      <WaitlistForm />
    </div>

    <!-- Developer link -->
    <p class="mt-8 text-sm text-gray-500 slide-fade" data-delay="600">
      Building a development?
      <a
        href="mailto:hello@tarahome.ai?subject=Developer Partnership Inquiry"
        class="underline underline-offset-4 hover:text-white transition-colors"
      >
        Talk to our team →
      </a>
    </p>
  </div>
</section>
