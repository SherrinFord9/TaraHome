---
// Waitlist email form — Formspree submission with honeypot
---

<form
  id="waitlist-form"
  action="https://formspree.io/f/xdkobqng"
  method="POST"
  class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto"
>
  <!-- Honeypot -->
  <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

  <input
    type="email"
    name="email"
    required
    placeholder="Enter your email"
    class="flex-1 bg-white/[0.04] border border-white/[0.08] rounded-full px-6 py-3.5 text-base text-white placeholder-gray-500 focus:outline-none focus:border-purple-400/30 focus:bg-white/[0.06] focus:shadow-[0_0_20px_rgba(161,0,255,0.08)] transition-all duration-300"
  />
  <button
    type="submit"
    class="btn-primary text-base px-8 py-3.5 whitespace-nowrap"
  >
    Get Early Access
  </button>
</form>

<!-- Success Message (hidden by default) -->
<p id="waitlist-success" class="hidden text-center text-green-400/80 text-sm mt-4">
  You're on the list. We'll be in touch.
</p>

<!-- Error Message (hidden by default) -->
<p id="waitlist-error" class="hidden text-center text-red-400/80 text-sm mt-4">
  Something went wrong. Please try again.
</p>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
  const success = document.getElementById('waitlist-success');
  const error = document.getElementById('waitlist-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { 'Accept': 'application/json' },
      });
      if (res.ok) {
        form.classList.add('hidden');
        success?.classList.remove('hidden');
      } else {
        error?.classList.remove('hidden');
      }
    } catch {
      error?.classList.remove('hidden');
    }
  });
</script>
