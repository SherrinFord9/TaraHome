---
// Features bento grid — 5 cards, first one spans 2 columns
---

<section id="features" class="relative z-10 py-24 md:py-32">
  <div class="mx-auto max-w-7xl px-6">

    <!-- Section Label -->
    <p class="section-label text-center slide-fade">Capabilities</p>

    <!-- Headline -->
    <h2 class="font-[var(--font-display)] text-3xl md:text-4xl font-extrabold text-center tracking-tight mb-16 heading-glow slide-scale" data-duration="1.1">
      <span class="heading-gradient">Everything Your Home Needs. Nothing It Doesn't.</span>
    </h2>

    <!-- Bento Grid -->
    <div class="grid md:grid-cols-2 gap-6">

      <!-- Card 1: Local AI (large, spans 2 cols) — slides up wide -->
      <div class="md:col-span-2 glass-card p-8 md:p-10 slide-scale" data-duration="1.0">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <h3 class="font-[var(--font-display)] text-xl font-semibold text-white mb-3">
              Local AI That Actually Understands You
            </h3>
            <p class="text-base text-gray-400 leading-relaxed">
              TARA runs a full language model on-device. Not a cloud lookup — real
              reasoning. Ask her to "make the living room cozy" and she'll dim the
              lights, adjust the thermostat, and close the blinds. In 2 seconds.
              Without internet.
            </p>
          </div>
          <div class="flex items-center justify-center">
            <!-- Abstract conversation UI mockup -->
            <div class="w-full max-w-xs space-y-3">
              <div class="flex justify-end">
                <div class="bg-white/[0.08] border border-white/[0.06] rounded-2xl rounded-br-sm px-4 py-2.5 text-sm text-gray-300 max-w-[80%]">
                  Make the living room cozy
                </div>
              </div>
              <div class="flex justify-start">
                <div class="bg-purple-500/[0.08] border border-purple-400/[0.1] rounded-2xl rounded-bl-sm px-4 py-2.5 text-sm text-gray-300 max-w-[80%]">
                  <span class="text-purple-400/80 text-xs block mb-1">TARA</span>
                  Dimming lights to 30%, setting thermostat to 72°, closing living room blinds. Cozy mode on.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Card 2: Presence Detection — slides from left -->
      <div class="glass-card p-8 slide-left">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-purple-500/[0.08] mb-5">
          <svg class="w-6 h-6 text-purple-500/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
            <circle cx="12" cy="12" r="4" stroke-dasharray="2,2"/>
            <circle cx="12" cy="12" r="7" stroke-dasharray="3,3" opacity="0.5"/>
          </svg>
        </div>
        <h3 class="font-[var(--font-display)] text-xl font-semibold text-white mb-3">
          Presence Without Cameras
        </h3>
        <p class="text-base text-gray-400 leading-relaxed">
          mmWave radar detects movement, breathing, even sleep — through walls.
          No camera. No footage. Just awareness. Lights follow you from room to
          room. The house knows you're home before you do.
        </p>
      </div>

      <!-- Card 3: Every Protocol — slides from right -->
      <div class="glass-card p-8 slide-right">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-purple-500/[0.08] mb-5">
          <svg class="w-6 h-6 text-purple-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <circle cx="12" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/>
            <path d="M12 7v5m0 0l-5.5 5M12 12l5.5 5"/>
          </svg>
        </div>
        <h3 class="font-[var(--font-display)] text-xl font-semibold text-white mb-3">
          Every Protocol, One Hub
        </h3>
        <p class="text-base text-gray-400 leading-relaxed">
          Zigbee. Matter. Thread. Z-Wave. Wi-Fi. Bluetooth. TARA speaks them
          all. No extra hubs, no compatibility headaches. 2,000+ devices work
          out of the box.
        </p>
      </div>

      <!-- Card 4: Natural Voice — slides from left, with background photo -->
      <div class="glass-card p-8 slide-left relative overflow-hidden">
        <!-- Background photo accent -->
        <img
          src="/assets/images/sections/feature-voice.jpg"
          alt=""
          aria-hidden="true"
          class="absolute inset-0 w-full h-full object-cover opacity-[0.07]"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[#0A0A0B]/80 to-transparent"></div>

        <div class="relative z-10">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-purple-500/[0.08] mb-5">
            <svg class="w-6 h-6 text-purple-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/>
              <path d="M19 10v2a7 7 0 01-14 0v-2M12 19v4m-4 0h8"/>
            </svg>
          </div>
          <h3 class="font-[var(--font-display)] text-xl font-semibold text-white mb-3">
            Voice That Feels Natural
          </h3>
          <p class="text-base text-gray-400 leading-relaxed">
            "Hey TARA, is the back door locked?" She answers in a natural voice —
            not a robotic assistant bark. Have a conversation, not a command session.
            Works from any room with voice satellites.
          </p>
        </div>
      </div>

      <!-- Card 5: Zero Fees — slides from right -->
      <div class="glass-card p-8 slide-right">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-purple-500/[0.08] mb-5">
          <svg class="w-6 h-6 text-purple-500/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path d="M9 14l6-6M4 4l16 16" stroke-linecap="round"/>
            <path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
          </svg>
        </div>
        <h3 class="font-[var(--font-display)] text-xl font-semibold text-white mb-3">
          Zero Monthly Fees. Forever.
        </h3>
        <p class="text-base text-gray-400 leading-relaxed">
          No subscriptions. No premium tiers. No "free trial ending soon."
          You buy TARA once. She's yours. Every update, every feature — included.
        </p>
      </div>
    </div>
  </div>
</section>
