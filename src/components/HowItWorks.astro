---
// How It Works — 3-step flow
const steps = [
  {
    num: '01',
    title: 'Plug In',
    body: 'Connect TARA to your network. She boots up and discovers your home in minutes — every light, lock, sensor, and switch.',
  },
  {
    num: '02',
    title: 'Say Hello',
    body: '"Hey TARA, I\'m home." That\'s it. She responds in natural conversation, not robotic commands. Ask her anything about your home.',
  },
  {
    num: '03',
    title: 'Let Her Learn',
    body: 'Over days, TARA learns your rhythms. Lights dim at bedtime. Coffee starts at sunrise. Doors lock when you leave. Automatically.',
  },
];
---

<section id="how-it-works" class="relative z-10 py-24 md:py-32">
  <div class="mx-auto max-w-7xl px-6">

    <!-- Section Label -->
    <p class="section-label text-center slide-fade">How It Works</p>

    <!-- Headline -->
    <h2 class="font-[var(--font-display)] text-3xl md:text-4xl font-extrabold text-center tracking-tight mb-16 heading-glow slide-scale" data-duration="1.1">
      <span class="heading-gradient">Three Steps to a Smarter Home.</span>
    </h2>

    <!-- Steps -->
    <div class="grid md:grid-cols-3 gap-8 relative">

      <!-- Connection line — draws in from left -->
      <div class="hidden md:block absolute top-24 left-[16.67%] right-[16.67%] h-px border-t border-dashed border-white/[0.08] draw-in" data-delay="400" data-duration="1.2" aria-hidden="true"></div>

      {steps.map((step) => (
        <div class="relative glass-card p-8 reveal">
          <!-- Gradient top border -->
          <div class="absolute top-0 left-4 right-4 h-px bg-gradient-to-r from-amber-400/50 via-amber-600/20 to-transparent"></div>

          <!-- Step number -->
          <span class="font-[var(--font-display)] text-6xl font-bold text-white/[0.07] block mb-4">
            {step.num}
          </span>

          <!-- Title -->
          <h3 class="font-[var(--font-display)] text-xl font-semibold text-white mb-3">
            {step.title}
          </h3>

          <!-- Body -->
          <p class="text-base text-gray-400 leading-relaxed">
            {step.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
