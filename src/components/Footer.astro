---
const year = new Date().getFullYear();
---

<footer class="relative z-10 border-t border-white/[0.06] bg-black">
  <div class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-8">

      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <img src="/assets/logo/tara-star.svg" alt="TARA" class="w-6 h-6" />
          <span class="font-[var(--font-display)] text-base font-semibold tracking-[0.3em]">
            TARA
          </span>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed">
          Locally intelligent.<br />
          Effortlessly human.
        </p>
      </div>

      <!-- Product -->
      <div>
        <p class="text-xs font-medium uppercase tracking-widest text-gray-400 mb-4">Product</p>
        <ul class="space-y-3">
          <li><a href="#features" class="text-sm text-gray-400 footer-link">Features</a></li>
          <li><a href="#how-it-works" class="text-sm text-gray-400 footer-link">How It Works</a></li>
          <li><a href="#developers" class="text-sm text-gray-400 footer-link">For Developers</a></li>
          <li><a href="/blog/" class="text-sm text-gray-400 footer-link">Blog</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <p class="text-xs font-medium uppercase tracking-widest text-gray-400 mb-4">Company</p>
        <ul class="space-y-3">
          <li><a href="mailto:hello@tarahome.ai" class="text-sm text-gray-400 footer-link">Contact</a></li>
          <li><a href="#waitlist" class="text-sm text-gray-400 footer-link">Get Early Access</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <p class="text-xs font-medium uppercase tracking-widest text-gray-400 mb-4">Legal</p>
        <ul class="space-y-3">
          <li><a href="/privacy/" class="text-sm text-gray-400 footer-link">Privacy Policy</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-16 pt-8 border-t border-white/[0.06] flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-400">
        &copy; {year} TARA. All rights reserved.
      </p>
      <div class="flex items-center gap-5">
        <a href="https://github.com" class="text-gray-500 hover:text-white transition-colors" aria-label="GitHub">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="https://twitter.com" class="text-gray-500 hover:text-white transition-colors" aria-label="Twitter">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
