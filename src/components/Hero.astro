---
// Hero section — full viewport, headline + CTAs left, abstract visual right
---

<section class="relative min-h-screen flex items-center pt-20 pb-16 overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 w-full">
    <div class="grid lg:grid-cols-5 gap-12 lg:gap-16 items-center">

      <!-- Text Column (60%) -->
      <div class="lg:col-span-3">
        <!-- Eyebrow — slides down from above -->
        <p class="section-label mb-6 slide-down" data-delay="100">
          Privacy-First Smart Home Intelligence
        </p>

        <!-- Headline — slides in from left -->
        <h1 class="font-[var(--font-display)] text-5xl md:text-6xl lg:text-7xl font-extrabold leading-[1.08] tracking-tight mb-6 heading-glow slide-left" data-delay="250" data-duration="1.1">
          <span class="heading-gradient-hero">Your Home Should Think</span>
          <span class="block text-gray-400">for Itself.</span>
        </h1>

        <!-- Subheadline — fades in -->
        <p class="text-lg md:text-xl text-gray-400 leading-relaxed max-w-xl mb-10 slide-fade" data-delay="500">
          TARA is a locally-intelligent home system that understands your habits,
          responds to your voice, and keeps every byte of data inside your walls.
          <strong class="text-white font-medium">No cloud. No cameras. No subscriptions. Ever.</strong>
        </p>

        <!-- CTA Buttons — slide up staggered -->
        <div class="flex flex-col sm:flex-row gap-4 mb-10 stagger-children">
          <a href="#waitlist" class="btn-primary text-base px-8 py-4 reveal" data-delay="650">
            Get Early Access
          </a>
          <a href="#developers" class="btn-secondary text-base px-8 py-4 reveal" data-delay="750">
            For Developers →
          </a>
        </div>

        <!-- Trust Strip — fades in last -->
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gray-600 tracking-wide slide-fade" data-delay="900">
          <span>Built on Home Assistant</span>
          <span class="text-gray-700">•</span>
          <span>Zigbee</span>
          <span class="text-gray-700">•</span>
          <span>Matter</span>
          <span class="text-gray-700">•</span>
          <span>Thread</span>
          <span class="text-gray-700">•</span>
          <span>Wi-Fi</span>
          <span class="text-gray-700">•</span>
          <span>Z-Wave</span>
        </div>
      </div>

      <!-- Visual Column — scales in from center -->
      <div class="lg:col-span-2 flex items-center justify-center slide-scale" data-delay="400" data-duration="1.2">
        <div class="relative w-72 h-72 md:w-80 md:h-80 lg:w-96 lg:h-96">
          <!-- Ambient glow behind orb -->
          <div class="absolute inset-0 rounded-full bg-gradient-to-br from-purple-500/20 via-purple-700/10 to-transparent blur-3xl animate-pulse"></div>

          <!-- Image orb — circular masked photo with float -->
          <div class="hero-orb absolute inset-8 rounded-full overflow-hidden border border-white/[0.06]">
            <img
              src="/assets/images/sections/hero-orb.jpg"
              alt="Mathematical and scientific diagrams representing TARA's intelligence"
              class="w-full h-full object-cover opacity-60"
              loading="eager"
            />
            <!-- Amber tint overlay -->
            <div class="absolute inset-0 bg-gradient-to-br from-purple-900/30 via-transparent to-purple-950/20 mix-blend-overlay"></div>
            <!-- Edge fade into background -->
            <div class="absolute inset-0 rounded-full shadow-[inset_0_0_60px_20px_rgba(5,5,5,0.8)]"></div>
          </div>

          <!-- Constellation device icons (overlaid on image) -->
          <div class="absolute inset-0">
            <div class="absolute top-4 left-1/2 -translate-x-1/2 text-purple-400/40">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            </div>
            <div class="absolute top-1/2 right-2 -translate-y-1/2 text-purple-500/40">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path d="M9 21h6M12 3a6 6 0 00-4 10.5V17h8v-3.5A6 6 0 0012 3z"/></svg>
            </div>
            <div class="absolute bottom-4 left-1/2 -translate-x-1/2 text-purple-400/40">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path d="M12 9V3m0 18a4 4 0 100-8 4 4 0 000 8z"/><path d="M12 9a2 2 0 00-2 2v4.5"/></svg>
            </div>
            <div class="absolute top-1/2 left-2 -translate-y-1/2 text-purple-500/40">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path d="M11 5L6 9H2v6h4l5 4V5zM19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>
            </div>
          </div>

          <!-- Connection lines -->
          <svg class="absolute inset-0 w-full h-full" viewBox="0 0 100 100">
            <line x1="50" y1="10" x2="50" y2="35" stroke="rgba(161,0,255,0.12)" stroke-width="0.5"/>
            <line x1="90" y1="50" x2="65" y2="50" stroke="rgba(161,0,255,0.10)" stroke-width="0.5"/>
            <line x1="50" y1="90" x2="50" y2="65" stroke="rgba(161,0,255,0.12)" stroke-width="0.5"/>
            <line x1="10" y1="50" x2="35" y2="50" stroke="rgba(161,0,255,0.10)" stroke-width="0.5"/>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-orb {
    animation: hero-float 6s ease-in-out infinite alternate;
  }
  @keyframes hero-float {
    0% { transform: translateY(0) scale(1); }
    100% { transform: translateY(-12px) scale(1.02); }
  }
</style>
