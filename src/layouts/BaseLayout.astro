---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'TARA is a locally-intelligent home system. No cloud. No cameras. No subscriptions.',
  ogImage = '/assets/images/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://tarahome.ai');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#000000" />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" type="image/svg+xml" href="/assets/logo/tara-star.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://tarahome.ai${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://tarahome.ai${ogImage}`} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q1R4JEF4T4"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-Q1R4JEF4T4');
    </script>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "TARA",
      "url": "https://tarahome.ai",
      "description": "TARA is a locally-intelligent home system. No cloud. No cameras. No subscriptions."
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "TARA Home Intelligence",
      "description": "A privacy-first smart home system that processes everything locally using on-device AI, mmWave presence detection, and multi-protocol device support.",
      "brand": { "@type": "Brand", "name": "TARA" },
      "url": "https://tarahome.ai",
      "offers": { "@type": "Offer", "availability": "https://schema.org/PreOrder", "url": "https://tarahome.ai" }
    })} />
  </head>
  <body class="min-h-screen overflow-x-hidden">
    <!-- Aurora Background -->
    <div class="aurora-bg" aria-hidden="true">
      <div class="aurora-blob"></div>
    </div>

    <!-- Page Content -->
    <div class="relative z-10">
      <slot />
    </div>

    <!-- Scroll Reveal Animations -->
    <script>
      import '../scripts/scroll-animations.js';
    </script>
  </body>
</html>
