---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  readTime: string;
}

const { title, description, date, category, readTime } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — TARA Blog`} description={description}>
  <Nav />

  <article class="relative z-10 pt-28 pb-24">
    <div class="mx-auto max-w-3xl px-6">

      <!-- Article Header -->
      <header class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-xs font-medium uppercase tracking-widest text-purple-400/60">{category}</span>
          <span class="text-gray-700">•</span>
          <span class="text-xs text-gray-500">{formattedDate}</span>
          <span class="text-gray-700">•</span>
          <span class="text-xs text-gray-500">{readTime}</span>
        </div>
        <h1 class="font-[var(--font-display)] text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight">
          {title}
        </h1>
      </header>

      <!-- Article Body -->
      <div class="prose prose-invert prose-lg max-w-none
        prose-headings:font-[var(--font-display)] prose-headings:font-semibold
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-gray-400 prose-p:leading-relaxed
        prose-a:text-purple-400 prose-a:underline prose-a:underline-offset-4 hover:prose-a:text-white
        prose-strong:text-white
        prose-li:text-gray-400
        prose-code:text-purple-300 prose-code:bg-white/[0.06] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
        prose-pre:bg-white/[0.03] prose-pre:border prose-pre:border-white/[0.06] prose-pre:rounded-xl
        prose-blockquote:border-purple-400/30 prose-blockquote:text-gray-400
        prose-table:text-sm prose-th:text-gray-300 prose-td:text-gray-400
        prose-hr:border-white/[0.06]
      ">
        <slot />
      </div>

      <!-- CTA Box -->
      <div class="mt-16 glass-card p-8 text-center">
        <h3 class="font-[var(--font-display)] text-xl font-semibold text-white mb-2">
          Ready for a smarter home?
        </h3>
        <p class="text-gray-400 mb-6">
          Join the waitlist and be among the first to experience TARA.
        </p>
        <a href="/#waitlist" class="btn-primary text-sm px-8 py-3">
          Get Early Access
        </a>
      </div>

      <!-- Back to Blog -->
      <div class="mt-10">
        <a href="/blog/" class="text-sm text-gray-500 hover:text-white transition-colors">
          ← Back to all articles
        </a>
      </div>
    </div>
  </article>

  <Footer />
</BaseLayout>
